{
  "_comment": "Output contract for the weekly macro run. Each entry declares the files a skill must produce. postrun_check.py reads this file and verifies every declared output exists on disk. Patterns are relative to --output-dir and support {week} (e.g. 2026-W13) and {date} (e.g. 2026-03-31) substitution.",

  "skills": {
    "skill_1_central_bank_watch": {
      "description": "Central Bank Watch",
      "outputs": [
        "collection/central-bank-watch/{week}-central-bank-watch.md"
      ]
    },
    "skill_2_liquidity_credit": {
      "description": "Liquidity & Credit Monitor",
      "outputs": [
        "collection/liquidity-credit/{week}-liquidity-credit.md"
      ]
    },
    "skill_3_macro_data": {
      "description": "Macro Data Tracker",
      "outputs": [
        "collection/macro-data/{week}-macro-data.md"
      ]
    },
    "skill_4_geopolitical": {
      "description": "Geopolitical & Policy Scanner",
      "outputs": [
        "collection/geopolitical/{week}-geopolitical.md"
      ]
    },
    "skill_5_positioning": {
      "description": "Market Positioning & Sentiment",
      "outputs": [
        "collection/positioning/{week}-positioning.md"
      ]
    },
    "skill_6_synthesis": {
      "description": "Weekly Macro Synthesis",
      "outputs": [
        "synthesis/{week}-synthesis.md"
      ]
    },
    "skill_6b_regime_evaluation": {
      "description": "Regime Evaluation",
      "outputs": [
        "synthesis/{week}-regime-evaluation.md",
        "synthesis/regime-evaluation-history.json"
      ]
    },
    "skill_7_thesis_monitor": {
      "description": "Thesis Generator & Monitor",
      "outputs": [
        "collection/{week}-thesis-monitor.md"
      ],
      "thesis_checks": {
        "description": "Every .md file in theses/active/ must have a companion -data.json sidecar and an Updated field matching today's date. Checked separately by postrun_check.py.",
        "active_dir": "theses/active/",
        "require_sidecar": true,
        "require_updated_today": true
      }
    },
    "skill_8_improvement": {
      "description": "Self-Improvement Loop",
      "outputs": [
        "improvement/{week}-improvement.md",
        "improvement/amendment-tracker.md",
        "improvement/accuracy-tracker.md"
      ]
    },
    "skill_9_briefing": {
      "description": "Monday Morning Memo",
      "outputs": [
        "briefings/{week}-briefing.md",
        "briefings/{week}-briefing-data.json"
      ]
    },
    "skill_10_analyst_monitor": {
      "description": "External Analyst Monitor",
      "outputs": [
        "collection/{week}-analyst-monitor.md",
        "collection/analyst-themes.md"
      ]
    },
    "dashboard": {
      "description": "HTML Dashboard",
      "outputs": [
        "briefings/{week}-dashboard.html",
        "regime-history.json"
      ]
    }
  },

  "optional_skills": {
    "skill_6c_empirical_sentiment": {
      "description": "Empirical Sentiment (Analog Matching) — runs after Skill 6 when synthesis-data.json is available",
      "outputs": [
        "synthesis/empirical-sentiment.json"
      ],
      "note": "Optional. Produces per-asset risk/reward ratios from historical analog matching. Consumed by trading-engine T1/T3. If missing, downstream consumers skip this signal gracefully."
    }
  },

  "conditional_skills": {
    "skill_11_structural_research": {
      "description": "Structural Research — MANDATORY when Skill 7 flags candidates",
      "condition": "Check Skill 7 meta block total_investigations_triggered > 0",
      "outputs_if_triggered": [
        "research/STRUCTURAL-*-{date}.md"
      ],
      "validation": {
        "count_must_match": "total_investigations_triggered from Skill 7 meta block",
        "deferred_field": "investigations_deferred_by_cap from Skill 7 meta block",
        "expected_briefs": "total_investigations_triggered - investigations_deferred_by_cap",
        "note": "The number of STRUCTURAL-*-{date}.md files produced today must equal (total_investigations_triggered - investigations_deferred_by_cap). Any mismatch means investigations were illegitimately skipped."
      }
    },
    "skill_13_structural_scanner": {
      "description": "Structural Scanner — bi-weekly",
      "condition_file": "structural/last-scan.json",
      "condition_field": "last_run_date",
      "condition_max_age_days": 12,
      "outputs_if_ran": [
        "structural/last-scan.json"
      ]
    },
    "skill_14_decade_horizon": {
      "description": "Decade Horizon — quarterly",
      "condition_file": "strategic/last-horizon.json",
      "condition_field": "last_run_date",
      "condition_max_age_days": 80,
      "outputs_if_ran": [
        "strategic/latest-horizon-map.md",
        "strategic/last-horizon.json"
      ]
    }
  }
}
